# Kinawa Command Center v2 - Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string-in-production
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://localhost/kinawa_cc_v2
DEV_DATABASE_URL=postgresql://localhost/kinawa_cc_v2_dev
TEST_DATABASE_URL=postgresql://localhost/kinawa_cc_v2_test

# Admin Credentials (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=kinawa2026
